# ============================================================
# wschat environment (development)
# Copy to .env and adjust. This file is committed as a template.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=wschat
POSTGRES_PASSWORD=wschat_dev_pass
POSTGRES_DB=wschat
DATABASE_URL=postgresql://wschat:wschat_dev_pass@localhost:5432/wschat?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=replace-with-openssl-rand-hex-48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Data Encryption (AES-256-GCM master key, 32 bytes => 64 hex chars) ----
DATA_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ---- MinIO (S3-compatible media storage) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=wschat-media
MINIO_REGION=us-east-1

# ---- LiveKit (video call SFU) ----
LIVEKIT_API_KEY=replace
LIVEKIT_API_SECRET=replace
LIVEKIT_URL=ws://localhost:7880

# ---- App ----
NODE_ENV=development
BACKEND_PORT=3001
WEB_PORT=3000
BACKEND_ORIGIN=http://localhost:3000
